{
  "name": "gtmaxxin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "opennextjs-cloudflare build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/dev/smoke-swarm.ts",
    "test-node": "tsx scripts/dev/test-node.ts",
    "langgraph:dev": "npx @langchain/langgraph-cli dev --config infra/langgraph.json",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "cf:sync-secrets": "bash scripts/deploy/cloudflare-sync-secrets.sh",
    "cf:dev-vars": "bash scripts/deploy/cloudflare-dev-vars.sh"
  },
  "dependencies": {
    "@langchain/core": "^0.3.42",
    "@langchain/langgraph": "^0.2.62",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@xyflow/react": "^12.4.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.3",
    "lucide-react": "^0.475.0",
    "motion": "^12.40.0",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260612.1",
    "@langchain/langgraph-cli": "^0.0.30",
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4.0.9",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "tailwindcss": "^4.0.9",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "wrangler": "^4.100.0"
  }
}
