# OpenRouter — OPENROUTERAPIKEY1 is the shared key for ALL agents.
# Only set OPENROUTERAPIKEY2–11 if you have extra keys for failover.
OPENROUTERAPIKEY1=sk-or-v1-your-key-here
OPENROUTERMODEL1=liquid/lfm-2.5-1.2b-instruct:free
OPENROUTERMODEL2=liquid/lfm-2.5-1.2b-thinking:free
OPENROUTERMODEL3=openai/gpt-oss-20b:free
OPENROUTERMODEL4=nvidia/nemotron-3.5-content-safety:free
OPENROUTERMODEL5=openai/gpt-oss-20b:free
OPENROUTERMODEL6=nvidia/nemotron-nano-12b-v2-vl:free
OPENROUTERMODEL7=nvidia/nemotron-nano-9b-v2:free
OPENROUTERMODEL8=nvidia/nemotron-nano-12b-v2-vl:free
OPENROUTERMODEL9=openai/gpt-oss-120b:free
OPENROUTERMODEL10=openai/gpt-oss-120b:free
OPENROUTERMODEL11=liquid/lfm-2.5-1.2b-instruct:free

# Tool APIs (optional — mock mode works without these)
FIRECRAWL_API_KEY=
TAVILY_API_KEY=

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=gtmaxxin

# Development — set MOCK_LLM=true for stub smoke tests
MOCK_LLM=false
MOCK_TOOLS=false
